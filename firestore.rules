rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin.
    // Admin status is granted via a Firebase Custom Claim (admin: true) set
    // through the Firebase Admin SDK — never hardcoded here.
    // To grant admin: admin.auth().setCustomUserClaims(uid, { admin: true })
    function isAdmin() {
      return request.auth != null
        && request.auth.token.admin == true;
    }

    // Memes collection
    match /memes/{memeId} {
      // Anyone can read memes
      allow read: if true;

      // Anyone can create memes (anonymous users), with field-length guards
      allow create: if request.resource.data.imageUrl is string
        && request.resource.data.imageUrl.size() <= 2048
        && request.resource.data.get('likes', 0) == 0
        && request.resource.data.get('topText', '').size() <= 500
        && request.resource.data.get('bottomText', '').size() <= 500
        && request.resource.data.get('memeText', '').size() <= 2000
        && request.resource.data.get('description', '').size() <= 2000
        && request.resource.data.get('username', '').size() <= 100
        && request.resource.data.get('tags', []).size() <= 20;

      // Anyone can update ONLY the likes field; admin can update anything
      allow update: if isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));

      // Only admin can delete memes
      allow delete: if isAdmin();
    }

    // Templates collection (future use)
    match /templates/{templateId} {
      // Anyone can read templates
      allow read: if true;

      // Only admin can create/update/delete templates
      allow create, update, delete: if isAdmin();
    }

    // Analytics collection (future use)
    match /analytics/{docId} {
      // Only admin can read/write analytics
      allow read, write: if isAdmin();
    }

    // Contact messages collection
    match /contact_messages/{messageId} {
      // Anyone can create contact messages, with field-length guards
      allow create: if request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 5000
        && request.resource.data.get('name', '').size() <= 100
        && request.resource.data.get('email', '').size() <= 200;

      // Only admin can read/update/delete messages
      allow read, update, delete: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────────────
    // Cuboid Studio (github.com/iddonaim/cuboid-studio)
    //
    // Cuboid Studio shares this Firebase project. This file is the DEPLOYED
    // source of truth — the deploy workflow ships it on every merge to main,
    // REPLACING the live ruleset. Cuboid Studio's collections must therefore
    // be covered here; rules missing from this file stop existing in
    // production. A reference copy lives in cuboid-studio/firestore.rules —
    // keep the two in sync when editing either.
    //
    // Model:
    //   projects/{projectId}                                  — owned doc
    //   projects/{projectId}/sites/{siteId}                   — subcollection
    //   projects/{projectId}/sites/{siteId}/compositions/{id} — subcollection
    //   lexicons/{lexiconId}                                  — owned doc
    //   translationLexicons/{lexiconId}                       — owned doc
    //
    // Only the authenticated owner (ownerId == request.auth.uid) may read or
    // write these; unauthenticated users get nothing.
    // ────────────────────────────────────────────────────────────────────

    // Lexicons — encode-mode vocabularies, scoped per owner.
    match /lexicons/{lexiconId} {
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;
    }

    // Translation lexicons — editable Pataphysical/Evolution vocabularies.
    match /translationLexicons/{lexiconId} {
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;
    }

    match /projects/{projectId} {
      // The owner field is set on create and must match the caller.
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;

      // Sites + compositions inherit access from the parent project's owner.
      match /sites/{siteId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;

        match /compositions/{compositionId} {
          allow read, write: if request.auth != null
            && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
        }
      }
    }
  }
}
